# Flask Configuration
FLASK_APP=backend.app:create_app
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=sqlite:///restaurant.db

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@lamaisonelegante.com

# Restaurant Settings
RESTAURANT_NAME=La Maison Élégante
RESTAURANT_EMAIL=info@lamaisonelegante.com
RESTAURANT_PHONE=+1 (555) 123-4567
RESTAURANT_ADDRESS=123 Gourmet Avenue, New York, NY 10001

# Rate Limiting
REDIS_URL=redis://localhost:6379/0

# Production Settings (only for production)
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_HTTPONLY=true
# SESSION_COOKIE_SAMESITE=Lax